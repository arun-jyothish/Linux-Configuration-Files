(defun my/copy-to-clipboard ()
  "Copy active region to system clipboard via xclip."
  (interactive)
  (if (use-region-p)
      (call-process-region (region-beginning) (region-end)
                           "xclip" nil nil nil "-selection" "clipboard")
    (message "No region selected")))

(defun my/set-tab-style (width &optional use-tabs)
  "Set tab width and optionally use real tabs."
  (setq-local tab-width width)
  (setq-local indent-tabs-mode (if use-tabs t nil)))

;;; ============================================================
;;; USER CONFIG  (runs after all layers are loaded)
;;; ============================================================

(defun dotspacemacs/user-config ()

  ;; ----------------------------------------------------------
  ;; Indentation per mode  (tab-width 8 + real tabs for C/C++)
  ;; ----------------------------------------------------------
  (dolist (hook '(c-mode-hook c++-mode-hook))
    (add-hook hook (lambda () (my/set-tab-style 8 t))))

  (dolist (hook '(markdown-mode-hook text-mode-hook org-mode-hook))
    (add-hook hook (lambda () (my/set-tab-style 4 nil))))

  ;; ----------------------------------------------------------
  ;; Undo-tree
  ;; ----------------------------------------------------------
  (require 'undo-tree)
  (global-undo-tree-mode 1)
  ;; Persist undo history between sessions
  (setq undo-tree-auto-save-history t
        undo-tree-history-directory-alist
        `(("." . ,(concat spacemacs-cache-directory "undo-tree-history/"))))

  ;; ----------------------------------------------------------
  ;; UI
  ;; ----------------------------------------------------------
  (scroll-bar-mode -1)
  (spacemacs/enable-transparency)

  ;; Custom startup banner text (shown after image)
  (with-eval-after-load 'core-banner
    (setq spacemacs-banner-text '("   [ H a c k  T h e  P l a n e t ]")))

  ;; ----------------------------------------------------------
  ;; Org mode
  ;; ----------------------------------------------------------
  (with-eval-after-load 'org
    ;; Open file types with the right external programs
    (setq org-file-apps
          '((auto-mode  . emacs)
            ("\\.pdf\\'" . "okular %s")
            ("\\.png\\'" . "gwenview %s")
            ("\\.mp4\\'" . "vlc %s")))

    ;; PlantUML
    (setq org-plantuml-jar-path
          "/home/arun-jyothish/.apps/plantuml/plantuml-web/plantuml.jar"
          org-plantuml-exec-mode 'jar)

    ;; Babel languages
    (org-babel-do-load-languages
     'org-babel-load-languages
     '((python     . t)
       (java       . t)
       (plantuml   . t)
       (emacs-lisp . t)
       (C          . t)
       (shell      . t)))

    ;; Skip confirmation prompts for code blocks
    (setq org-confirm-babel-evaluate nil))

  ;; ----------------------------------------------------------
  ;; Browser
  ;; ----------------------------------------------------------
  (setq browse-url-generic-program "qutebrowser"
        browse-url-browser-function 'browse-url-generic)

  ;; ----------------------------------------------------------
  ;; Keybindings
  ;; ----------------------------------------------------------
  (global-set-key (kbd "C-c i") #'imenu)
  (global-set-key (kbd "C-c y") #'my/copy-to-clipboard))

