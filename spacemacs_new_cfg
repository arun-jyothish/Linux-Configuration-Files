;;; ============================================================
;;; LAYERS
;;; ============================================================

(defun dotspacemacs/layers ()
  (setq-default
   dotspacemacs-distribution 'spacemacs
   dotspacemacs-enable-lazy-installation 'unused
   dotspacemacs-ask-for-lazy-installation t
   dotspacemacs-configuration-layer-path '()

   dotspacemacs-configuration-layers
   '(auto-completion
     emacs-lisp
     helm
     markdown
     multiple-cursors
     org
     which-key
     spell-checking
     syntax-checking
     treemacs
     html
     javascript
     ;; python layer (once, not duplicated)
     (python :variables
             python-backend 'lsp
             python-lsp-server 'pyright)
     ;; LSP with sane defaults
     (lsp :variables
          lsp-enable-on-type-formatting nil
          lsp-prefer-flymake nil
          lsp-idle-delay 0.5)
     ;; C/C++ via LSP
     (c-c++ :variables
            c-c++-backend 'lsp-clangd)
     ;; Undo tree with region support
     (undo-tree :variables
                undo-tree-enable-undo-in-region t)
     ;; Shell at bottom
     (shell :variables
            shell-default-height 30
            shell-default-position 'bottom
            shell-default-shell 'vterm))

   dotspacemacs-additional-packages
   '(klere-theme
     darkokai-theme
     vs-dark-theme
     doom-themes
     rainbow-mode
     vterm
     magit
     plantuml-mode)

   ;; NOTE: removed duplicate 'python', 'undo-tree', 'spacemacs-theme',
   ;; 'python-mode' (superseded by python layer), and 'vs-dark-theme' duplicate.

   dotspacemacs-frozen-packages '()
   dotspacemacs-excluded-packages '()
   dotspacemacs-install-packages 'used-only

   dotspacemacs/elpa-archives
   '(("melpa" . "https://melpa.org/packages/")
     ("gnu"   . "https://elpa.gnu.org/packages/")
     ("org"   . "https://orgmode.org/elpa/"))))

