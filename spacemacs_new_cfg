;;; INIT
;;; ============================================================

(defun dotspacemacs/init ()
  (setq-default
   ;; --- Performance ---
   dotspacemacs-gc-cons '(100000000 0.1)
   dotspacemacs-read-process-output-max (* 1024 1024) ; 1 MB — helps LSP

   ;; --- Editing style ---
   dotspacemacs-editing-style 'emacs

   ;; --- Appearance ---
   dotspacemacs-themes '(darkokai vs-dark spacemacs-dark spacemacs-light)
   dotspacemacs-mode-line-theme '(spacemacs :separator wave :separator-scale 1.5)
   dotspacemacs-colorize-cursor-according-to-state t
   dotspacemacs-default-font '("Fira Code" :size 12 :weight bold :width normal)
   dotspacemacs-mode-line-unicode-symbols t
   dotspacemacs-startup-banner "~/.emacs.d/fox-hacker.png"
   dotspacemacs-startup-banner-scale 'auto
   dotspacemacs-startup-buffer-show-version t
   dotspacemacs-startup-buffer-show-icons nil
   dotspacemacs-startup-buffer-show-logo nil

   ;; --- Startup lists ---
   dotspacemacs-startup-lists '((recents . 5) (projects . 7))
   dotspacemacs-startup-buffer-responsive t
   dotspacemacs-show-startup-list-numbers t
   dotspacemacs-startup-buffer-multi-digit-delay 0.4

   ;; --- Frame ---
   dotspacemacs-maximized-at-startup nil
   dotspacemacs-fullscreen-at-startup nil
   dotspacemacs-fullscreen-use-non-native nil
   dotspacemacs-undecorated-at-startup nil
   dotspacemacs-active-transparency 90
   dotspacemacs-inactive-transparency 70
   dotspacemacs-background-transparency 64
   dotspacemacs-frame-title-format "%I@%S"
   dotspacemacs-icon-title-format nil

   ;; --- Scratch / buffers ---
   dotspacemacs-scratch-mode 'org-mode
   dotspacemacs-scratch-buffer-persistent nil
   dotspacemacs-scratch-buffer-unkillable nil
   dotspacemacs-initial-scratch-message nil
   dotspacemacs-new-empty-buffer-major-mode 'text-mode
   dotspacemacs-large-file-size 1

   ;; --- Keys ---
   dotspacemacs-leader-key "SPC"
   dotspacemacs-emacs-command-key "SPC"
   dotspacemacs-ex-command-key ":"
   dotspacemacs-emacs-leader-key "M-m"
