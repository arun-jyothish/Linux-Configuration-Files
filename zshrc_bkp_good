# chromium kiosk browser; full screen; no transparency bg run; clean for presentation
cf () {
  if [ $# -eq 0 ]; then
    echo "Usage: cf <file1.html> [file2.html ...]"
    return 1
  fi

  for f in "$@"; do
    file=$(realpath "$f")
    profile="/tmp/chrome-$(date +%s%N)-$RANDOM"

    # Create temporary wrapper
    wrapper="/tmp/cf-wrap-$(date +%s%N)-$RANDOM.html"

    cat > "$wrapper" <<EOF
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
html, body {
  margin: 0;
  height: 100%;
  overflow: hidden;
}
iframe {
  border: none;
  width: 100%;
  height: 100%;
}
::-webkit-scrollbar {
  display: none;
}
</style>
</head>
<body>
  <iframe src="file://$file"></iframe>
</body>
</html>
EOF

chromium \
	--class=cf-chromium \
	--kiosk "file://$wrapper" \
	--user-data-dir="$profile" \
	--no-first-run \
	--no-default-browser-check \
	--disable-background-networking \
	--log-level=3 \
	2>/dev/null &
done
}
