xss () {
	local var=$1
	prev_clip="/tmp/prev_clip"
	curr_clip="/tmp/curr_clip"
	diff_clip="/tmp/diff_clip"

	if [ -e "$curr_clip" ]; then
		cat "$curr_clip" > $prev_clip
	else
		touch $curr_clip
	fi
	echo "" >> $prev_clip
	tail -n $(wc $prev_clip -l) $curr_clip > $diff_clip
}

